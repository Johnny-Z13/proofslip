{
  "name": "@proofslip/mcp-server",
  "version": "0.2.3",
  "mcpName": "ai.proofslip/mcp-server",
  "description": "MCP server for ProofSlip — receipt-based verification for AI agent workflows",
  "type": "module",
  "bin": {
    "proofslip-mcp": "dist/bin/cli.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "smithery.yaml",
    "server.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@proofslip/sdk": "^0.1.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "proofslip",
    "receipts",
    "ai-agents",
    "model-context-protocol",
    "verification"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Johnny-Z13/proofslip.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://proofslip.ai",
  "bugs": {
    "url": "https://github.com/Johnny-Z13/proofslip/issues"
  }
}
